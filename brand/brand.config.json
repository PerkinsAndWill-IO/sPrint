{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "sPrint",
  "tagline": "Seamless Autodesk Cloud Printing",
  "description": "Batch-print PDFs and download derivatives from Autodesk Cloud (BIM360/ACC)",

  "logos": {
    "icon": {
      "svg": "./logos/icon.svg",
      "png": {
        "16": "./logos/icon-16.png",
        "32": "./logos/icon-32.png",
        "48": "./logos/icon-48.png",
        "128": "./logos/icon-128.png"
      }
    },
    "wordmark": {
      "svg": "./logos/wordmark.svg"
    },
    "wordmarkWithIcon": {
      "svg": "./logos/wordmark-with-icon.svg"
    },
    "favicon": {
      "svg": "./logos/icon.svg",
      "ico": "./logos/favicon.ico"
    },
    "usage": {
      "light_background": "Use dark logo fill (#1e2330 or currentColor)",
      "dark_background": "Use white logo fill (#ffffff or currentColor)",
      "minimum_clear_space": "Equal to the height of the 's' in sPrint wordmark"
    }
  },

  "colors": {
    "brand": {
      "primary": {
        "name": "Green",
        "light": {
          "default": "#00C16A",
          "hover": "#00A155",
          "subtle": "#EFFDF5",
          "muted": "#D9FBE8"
        },
        "dark": {
          "default": "#00DC82",
          "hover": "#00C16A",
          "subtle": "#052E16",
          "muted": "#0A5331"
        },
        "palette": {
          "50":  "#EFFDF5",
          "100": "#D9FBE8",
          "200": "#B3F5D1",
          "300": "#75EDAE",
          "400": "#00DC82",
          "500": "#00C16A",
          "600": "#00A155",
          "700": "#007F45",
          "800": "#016538",
          "900": "#0A5331",
          "950": "#052E16"
        }
      },
      "neutral": {
        "name": "Gray",
        "tailwind_name": "gray"
      }
    },

    "semantic": {
      "success":  { "light": "#00C16A", "dark": "#00DC82", "tailwind": "green" },
      "error":    { "light": "#EF4444", "dark": "#F87171", "tailwind": "red" },
      "warning":  { "light": "#EAB308", "dark": "#FACC15", "tailwind": "yellow" },
      "info":     { "light": "#3B82F6", "dark": "#60A5FA", "tailwind": "blue" }
    },

    "backgrounds": {
      "light": {
        "page": "#FFFFFF",
        "surface": "#F9FAFB",
        "elevated": "#FFFFFF",
        "theme_color_meta": "#FFFFFF"
      },
      "dark": {
        "page": "#1b1718",
        "surface": "#1E293B",
        "elevated": "#334155",
        "theme_color_meta": "#1b1718"
      }
    },

    "text": {
      "light": {
        "primary": "#111827",
        "secondary": "#4B5563",
        "muted": "#9CA3AF",
        "on_primary": "#FFFFFF"
      },
      "dark": {
        "primary": "#F9FAFB",
        "secondary": "#D1D5DB",
        "muted": "#6B7280",
        "on_primary": "#052E16"
      }
    },

    "borders": {
      "light": {
        "default": "#E5E7EB",
        "strong": "#D1D5DB"
      },
      "dark": {
        "default": "#374151",
        "strong": "#4B5563"
      }
    },

    "logo": {
      "icon_background": "#1e2330",
      "icon_foreground": "#FFFFFF"
    },

    "format_badges": {
      "pdf":       { "semantic": "error",   "description": "Red" },
      "dwg":       { "semantic": "primary", "description": "Green" },
      "dwf":       { "semantic": "secondary", "description": "Blue" },
      "ifc":       { "semantic": "info",    "description": "Blue" },
      "thumbnail": { "semantic": "neutral", "description": "Gray" },
      "aec":       { "semantic": "info",    "description": "Blue" },
      "sdb":       { "semantic": "warning", "description": "Yellow" },
      "svf":       { "semantic": "success", "description": "Green" },
      "other":     { "semantic": "neutral", "description": "Gray" }
    }
  },

  "typography": {
    "font_family": {
      "primary": "Public Sans",
      "fallback": "sans-serif",
      "css_value": "'Public Sans', sans-serif",
      "source": "Google Fonts",
      "url": "https://fonts.google.com/specimen/Public+Sans"
    },
    "monospace": {
      "css_value": "ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, 'Liberation Mono', monospace"
    },
    "scale": {
      "xs":   { "size": "0.75rem",  "line_height": "1rem" },
      "sm":   { "size": "0.875rem", "line_height": "1.25rem" },
      "base": { "size": "1rem",     "line_height": "1.5rem" },
      "lg":   { "size": "1.125rem", "line_height": "1.75rem" },
      "xl":   { "size": "1.25rem",  "line_height": "1.75rem" },
      "2xl":  { "size": "1.5rem",   "line_height": "2rem" }
    },
    "weights": {
      "regular":  400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    }
  },

  "spacing": {
    "unit": "0.25rem",
    "scale": {
      "1":  "0.25rem",
      "2":  "0.5rem",
      "3":  "0.75rem",
      "4":  "1rem",
      "6":  "1.5rem",
      "8":  "2rem",
      "12": "3rem",
      "16": "4rem"
    }
  },

  "border_radius": {
    "sm":   "0.25rem",
    "md":   "0.375rem",
    "lg":   "0.5rem",
    "xl":   "0.75rem",
    "2xl":  "1rem",
    "full": "9999px"
  },

  "icons": {
    "library": "Lucide",
    "package": "@iconify-json/lucide",
    "prefix": "i-lucide-",
    "key_icons": {
      "theme_dark": "i-lucide-moon",
      "theme_light": "i-lucide-sun",
      "theme_toggle": "i-lucide-sun-moon",
      "settings": "i-lucide-palette",
      "logout": "i-lucide-log-out",
      "navigation": "i-lucide-chevrons-up-down"
    }
  },

  "color_mode": {
    "default": "dark",
    "supported": ["light", "dark"],
    "user_customizable_primary_colors": [
      "red", "orange", "amber", "yellow", "lime", "green", "emerald",
      "teal", "cyan", "sky", "blue", "indigo", "violet", "purple",
      "fuchsia", "pink", "rose"
    ],
    "user_customizable_neutral_colors": [
      "slate", "gray", "zinc", "neutral", "stone"
    ]
  },

  "css_framework": {
    "name": "Tailwind CSS",
    "version": "4.x",
    "ui_library": "Nuxt UI",
    "ui_version": "4.x"
  }
}
